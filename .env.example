# ---- 必填 ----
# OpenRouter：relevance 打分 + tier 分层 + pitch angle 生成
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 可选：OpenRouter 礼貌头
OPENROUTER_REFERER=
OPENROUTER_TITLE=sd-journofinder

# NewsAPI.ai (Event Registry)：主源，按品牌关键词查近期文章 → 解析记者署名 + 媒体
# 申请免费 key（2000 搜/月，近 30 天）：https://newsapi.ai/
NEWSAPI_AI_KEY=
NEWSAPI_AI_URL=https://eventregistry.org/api/v1/article/getArticles

# ---- 可选（补召 + 深挖，未设则自动跳过该能力）----
# Apodex（原 MiroMind 升级版）：补召独立记者 + Tier-A 联系方式深挖与 verified quotes
APODEX_API_KEY=
APODEX_BASE_URL=https://api.apodex.ai/v1

# Querit：补召网搜
QUERIT_API_TOKEN=
QUERIT_SEARCH_URL=https://api.querit.ai/v1/search

# Brave：补召网搜
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search

# ---- 模型覆盖（可选）----
JOURNO_RELEVANCE_MODEL=deepseek/deepseek-chat-v3.1
JOURNO_PITCH_MODEL=anthropic/claude-sonnet-4.6
JOURNO_DEEPDIVE_MODEL=apodex-1-0-deepresearch
